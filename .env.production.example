# =============================================================================
# FinPulse / SocPrints Platform — Production .env for VPS
# Copy: cp .env.production.example .env
# Then edit ALL values marked CHANGE_ME before deploy.
# =============================================================================

# --- Domain & URLs (must match your VPS domain) ---
DOMAIN=yourdomain.com
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com

# For first deploy via IP only (no SSL yet), use:
# FRONTEND_URL=http://YOUR_VPS_IP
# BACKEND_URL=http://YOUR_VPS_IP
# NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP

# --- PostgreSQL (internal Docker network) ---
POSTGRES_USER=finpulse
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=finpulse

# IMPORTANT: set these explicitly in .env (docker-compose does NOT override them).
# If password contains special chars (! @ # : / ?), URL-encode them:
#   ! -> %21   @ -> %40   # -> %23   : -> %3A
# Example: password "Fp2026_SecureDb!" becomes Fp2026_SecureDb%21 in URLs below.
DATABASE_URL=postgresql+asyncpg://finpulse:CHANGE_ME_strong_db_password@db:5432/finpulse
DATABASE_URL_SYNC=postgresql://finpulse:CHANGE_ME_strong_db_password@db:5432/finpulse

# --- Redis (internal) ---
REDIS_URL=redis://redis:6379/0

# --- App ---
APP_NAME=FinPulse
APP_ENV=production
DEBUG=false
UVICORN_WORKERS=1

# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_random_64_char_secret

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Stripe (Visa / Mastercard / Amex — card payments) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# --- PayPal ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
PAYPAL_WEBHOOK_ID=

# --- SendGrid (abandoned cart + order confirmation emails) ---
SENDGRID_API_KEY=SG....
FROM_EMAIL=noreply@yourdomain.com

# --- Optional integrations ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APIDECK_API_KEY=
APIDECK_APP_ID=
APIDECK_CONSUMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
LITELLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# --- BurgerPrints (POD fulfillment) ---
BURGERPRINTS_API_BASE_URL=https://api.burgerprints.com
BURGERPRINTS_API_KEY=
BURGERPRINTS_DEFAULT_FULFILLMENT_LOCATION=US
BURGERPRINTS_AUTO_PAY=false
BURGERPRINTS_WEBHOOK_SECRET=CHANGE_ME_random_webhook_secret

# --- Docker ports (nginx) ---
HTTP_PORT=80
HTTPS_PORT=443
