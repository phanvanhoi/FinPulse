# Database
DATABASE_URL=postgresql+asyncpg://finpulse:finpulse@localhost:5432/finpulse
DATABASE_URL_SYNC=postgresql://finpulse:finpulse@localhost:5432/finpulse

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apideck (QuickBooks integration)
APIDECK_API_KEY=
APIDECK_APP_ID=
APIDECK_CONSUMER_ID=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# LLM
LITELLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# Stripe (Visa, Mastercard, Amex via Stripe Checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

# SendGrid
SENDGRID_API_KEY=
FROM_EMAIL=noreply@finpulse.io

# BurgerPrints (POD fulfillment)
BURGERPRINTS_API_BASE_URL=https://api.burgerprints.com
BURGERPRINTS_API_KEY=
BURGERPRINTS_DEFAULT_FULFILLMENT_LOCATION=US
BURGERPRINTS_AUTO_PAY=false
BURGERPRINTS_WEBHOOK_SECRET=

# App
APP_NAME=FinPulse
APP_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# For VPS production, copy .env.production.example to .env instead
